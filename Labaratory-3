#include <iostream>
#include <stdexcept>
#include <random>
#include <cstdlib>

void InputSize(int32_t& size) {
    std::cout << "Input size: " << std::endl;
    std::cin >> size;
    if (size <= 0) {
        throw std::invalid_argument("Wrong size");
    }
}

void CreateArray(int32_t*& array, int32_t size) {
    array = new int32_t[size];
}

void FillArray(int32_t* array, int32_t size) {
    srand(time(0));
    for (size_t i = 0; i < size; ++i) {
        std::cout << "Enter value for element " << i << ": ";
        array[i] = rand()%100;
        std::cout<<std::endl;
    }
}

void PrintArray(int32_t* array, int32_t size) {
    std::cout << "Array elements: ";
    for (size_t i = 0; i < size; ++i) {
        std::cout << array[i] << " ";
    }
    std::cout << std::endl;
}

void DeleteArray(int32_t*& array) {
    delete[] array;
}

int main() {
    try {
        int32_t size{};
        InputSize(size);
        int32_t* array = nullptr;
        CreateArray(array, size);
        FillArray(array, size);
        PrintArray(array, size);
        DeleteArray(array);
    }
    catch (std::invalid_argument& e) {
        std::cout << "Code invalid: " << e.what() << std::endl;
    }
    catch (std::bad_alloc& e) {
        std::cout << "Memory allocation failed: " << e.what() << std::endl;
    }

    return 0;
}
